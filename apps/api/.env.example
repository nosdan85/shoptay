# =============================================================================
# NOS MARKET - ENVIRONMENT VARIABLES
# =============================================================================

# Application
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/nosmarket
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000

# =============================================================================
# JWT & SECURITY
# =============================================================================

JWT_SECRET=your_jwt_secret_min_32_chars_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_KEY=your_32_char_encryption_key_here_change_in_production

# =============================================================================
# DISCORD
# =============================================================================

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_guild_id
DISCORD_OWNER_ROLE_ID=your_owner_role_id
DISCORD_VOUCH_CHANNEL_ID=your_vouch_channel_id
DISCORD_TICKET_CATEGORY_ID=your_ticket_category_id
DISCORD_BOT_API_URL=http://localhost:3001

# Owner Discord IDs (comma-separated)
OWNER_DISCORD_IDS=your_discord_id_1,your_discord_id_2

# =============================================================================
# PAYPAL (Friends & Family - Manual)
# =============================================================================

# PayPal email for F&F payments
PAYPAL_EMAIL=your-paypal@email.com

# PayPal REST API (for future PayPal Checkout integration)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# =============================================================================
# NOWPAYMENTS (Litecoin)
# =============================================================================

NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret
NOWPAYMENTS_SANDBOX=false
NOWPAYMENTS_IPN_CALLBACK_URL=https://yourdomain.com/api/shop/webhook/nowpayments

# =============================================================================
# SQUARE (Cash App Pay)
# =============================================================================

SQUARE_APPLICATION_ID=sandbox-sq0idb-xxx
SQUARE_ACCESS_TOKEN=sandbox-sq0atb-xxx
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key

# Cash App Tag (for display in guides)
CASHAPP_TAG=$yoko276
