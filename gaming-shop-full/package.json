{
  "name": "nosmarket",
  "version": "1.0.0",
  "private": true,
  "description": "Nos Market - Gaming Items Marketplace built with Next.js 14, NestJS, PostgreSQL, Redis, and Discord.js",
  "license": "MIT",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@nosmarket/api",
    "build:web": "turbo run build --filter=@nosmarket/web",
    "build:bot": "turbo run build --filter=@nosmarket/bot",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@nosmarket/api",
    "dev:web": "turbo run dev --filter=@nosmarket/web",
    "dev:bot": "turbo run dev --filter=@nosmarket/bot",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=@nosmarket/api",
    "start:web": "turbo run start --filter=@nosmarket/web",
    "start:bot": "turbo run start --filter=@nosmarket/bot",
    "start:prod": "docker-compose -f docker-compose.yml up -d",
    "start:prod:build": "docker-compose -f docker-compose.yml build && docker-compose -f docker-compose.yml up -d",
    "stop:prod": "docker-compose -f docker-compose.yml down",
    "restart:prod": "docker-compose -f docker-compose.yml restart",
    "logs": "docker-compose -f docker-compose.yml logs -f",
    "logs:api": "docker-compose -f docker-compose.yml logs -f api",
    "logs:web": "docker-compose -f docker-compose.yml logs -f web",
    "logs:bot": "docker-compose -f docker-compose.yml logs -f bot",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "test:ci": "turbo run test -- --ci",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test -- --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" --ignore-path .gitignore",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "turbo run db:seed",
    "db:studio": "prisma studio",
    "db:console": "prisma db console",
    "db:reset": "docker-compose exec postgres psql -U postgres -d nosmarket -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;'",
    "clean": "turbo run clean && rm -rf node_modules && rm -rf .turbo",
    "clean:builds": "turbo run clean",
    "clean:docker": "docker-compose -f docker-compose.yml down -v --rmi local",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix",
    "deploy": "./scripts/deploy.sh",
    "deploy:rollback": "./scripts/rollback.sh",
    "healthcheck": "docker exec nosmarket-api wget -qO- http://localhost:3001/health",
    "migrate:up": "docker exec nosmarket-api npx prisma migrate deploy",
    "seed": "docker exec nosmarket-api npx prisma db seed",
    "postinstall": "pnpm generate:turbo-lockfile",
    "generate:turbo-lockfile": "turbo daemon --port 9080 || true",
    "precommit": "lint-staged",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^20.11.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/platform-express": "^10.0.0"
      },
      "ignoreMissing": [
        "webpack"
      ]
    }
  }
}
