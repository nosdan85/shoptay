# Backend API URL (required)
# Do not use localhost in production deploys.
VITE_API_URL=https://your-backend.onrender.com

# Public Discord vars for frontend (required)
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_REDIRECT_URI=https://nosmarket.com/auth/discord/callback
VITE_DISCORD_GUILD_ID=
VITE_DISCORD_VOUCH_CHANNEL_ID=
VITE_DISCORD_LINK_CHANNEL_ID=

# Vercel serverless Discord exchange (required for one-click login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://nosmarket.com/auth/discord/callback
BACKEND_AUTH_BRIDGE_URL=https://your-backend.onrender.com/api/shop/auth/discord-bridge
DISCORD_AUTH_BRIDGE_SECRET=replace_with_long_random_secret

# Optional frontend links
VITE_DISCORD_INVITE_URL=https://discord.gg/xxxx
VITE_TRUSTPILOT_URL=
