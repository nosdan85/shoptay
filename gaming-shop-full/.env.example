# Postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/nosmarket
POSTGRES_DB=nosmarket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# API
NODE_ENV=development
PORT=3001
JWT_SECRET=change_me_min_32_chars_here
JWT_EXPIRES_IN=7d
API_URL=http://localhost:3001

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_OWNER_ROLE_ID=
DISCORD_VOUCH_CHANNEL_ID=
DISCORD_TICKET_CATEGORY_ID=
DISCORD_INVITE_URL=https://discord.gg/nosmarket

# Admin
OWNER_DISCORD_IDS=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Square (Cash App Pay)
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox

# NOWPayments (Litecoin)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_KEY=

# Frontend
